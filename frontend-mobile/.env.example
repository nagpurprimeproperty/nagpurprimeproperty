# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values for local development.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Non-sensitive public API URLs (safe to bundle into JS)
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# ── GOOGLE MAPS API KEY ───────────────────────────────────────────────────────
# DO NOT define EXPO_PUBLIC_GOOGLE_MAPS_API_KEY here or in .env.
# EXPO_PUBLIC_* values are statically embedded in the JS bundle by Metro.
#
# The Maps key is managed as an EAS Build secret (never bundled into JS):
#   eas secret:create --scope project --name GOOGLE_MAPS_API_KEY --value <key>
#
# For local native builds (expo run:android / expo run:ios), export it in
# your shell before building — it is read by app.config.js at build time:
#   export GOOGLE_MAPS_API_KEY="AIza..."   # bash/zsh
#   $env:GOOGLE_MAPS_API_KEY="AIza..."     # PowerShell
