# ─── DATABASE & CACHING CREDENTIALS ──────────────────────────────────────────
# Username for MongoDB root admin (defaults to admin if blank)
MONGO_INITDB_ROOT_USERNAME=admin
# Secure database password for MongoDB
MONGO_INITDB_ROOT_PASSWORD=your_production_secure_db_password

# Redis password for cache and BullMQ queues
REDIS_PASSWORD=your_production_secure_redis_password

# ─── JWT AUTHENTICATION SECRETS ──────────────────────────────────────────────
# Generate secure keys using: openssl rand -hex 64
JWT_SECRET=your_production_jwt_access_secret_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_production_jwt_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ─── S3 BUCKET CONFIGURATION ──────────────────────────────────────────────────
S3_REGION=ap-south-1
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_ACCESS_KEY=your_production_s3_access_key
S3_SECRET_KEY=your_production_s3_secret_key
S3_BUCKET=your_production_bucket_name
S3_PUBLIC_URL=https://your_production_bucket_url.com

# ─── EMAIL CONFIGURATION (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_production_smtp_password

# ─── SMS GATEWAY (MSG91) ──────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_production_msg91_auth_key
MSG91_TEMPLATE_ID=your_production_msg91_otp_template_id

# ─── GOOGLE MAPS API KEYS ─────────────────────────────────────────────────────
# Server-side API key (used by backend/admin)
GOOGLE_MAPS_API_KEY=your_production_server_maps_key
# Client-side API key (used in web frontend - build time)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_production_client_maps_key

# ─── PAYMENTS (RAZORPAY) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_production_razorpay_key_id
RAZORPAY_KEY_SECRET=your_production_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_production_razorpay_webhook_secret

# ─── FIREBASE / PUSH NOTIFICATIONS ────────────────────────────────────────────
# OPTION A: Full Firebase Admin SDK service account JSON on one line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# OPTION B: Separate fields (alternative to JSON block above)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client-Side Web Configuration (Admin UI)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_firebase_vapid_key

# ─── SITE HOST & URL CONFIGURATION ────────────────────────────────────────────
# Production public API domain
NEXT_PUBLIC_API_URL=https://api.nagpurprimeproperty.com
# Production website domain
NEXT_PUBLIC_SITE_URL=https://nagpurprimeproperty.com
# Production admin website domain
NEXT_PUBLIC_WEBSITE_URL=https://admin.nagpurprimeproperty.com
# CORS allowed origins list (comma-separated)
ALLOWED_ORIGINS=https://nagpurprimeproperty.com,https://admin.nagpurprimeproperty.com
# Public facing URLs
FRONTEND_URL=https://nagpurprimeproperty.com
BACKEND_URL=https://api.nagpurprimeproperty.com
